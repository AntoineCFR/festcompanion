<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- N'autorise que les CA système (pas les certificats installés par l'utilisateur).
         Empêche les attaques MITM via un certificat proxy (Charles, mitmproxy, etc.). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- ✅ Autorise spécifiquement ton domaine (Render) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">extremalineup.onrender.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>